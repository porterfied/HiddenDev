function tycoonLib.Station(TycoonInstance)
	local TycoonData = TycoonInstance.TycoonData
	
	local objName = "Station"
	
	tycoonLib.TouchBuy(TycoonInstance,objName,function()
		local StationObj = tycoonLib.ReturnObj(objName).new(TycoonInstance,TycoonData["Station"])
		StationObj:Setup()
	end)
end

function tycoonLib.Wall(TycoonInstance)
	local TycoonData = TycoonInstance.TycoonData
	local TycoonBuilding = TycoonInstance.Tycoon.Building
	local WALLLIMIT = 4 * TycoonData.Station
	
	if TycoonData.Wall == WALLLIMIT then
		tycoonLib.Stairs(TycoonInstance)
		return
	end
	
	tycoonLib.TouchBuy(TycoonInstance,"Wall",function()
		tycoonLib.ReturnObj("Wall").new(TycoonBuilding["Wall"..tostring(TycoonData.Wall)]):SpawnObj()
		tycoonLib.Wall(TycoonInstance)	
	end)	
end
