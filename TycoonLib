function tycoonLib.ReturnObj(objName)
	return require(serverStorage.Scripts:WaitForChild(objName.."Script"))
end
-- caluates the price by seeing what level the player is on
function tycoonLib.PriceCalu(ObjName,ObjsOwned)

	local price = Prices[ObjName][ObjsOwned]
	
	if price == nil then
		warn("Array index out of bound for price. "..ObjName.." Index = "..tostring(price))
		return 
	end
	
	return price
end

function tycoonLib.LevelCalu(objName,levelLocation,index)
	if typeof(levelLocation) == "number" then
		return Levels[objName][levelLocation]
	end 
	return Levels[objName][index]
end

