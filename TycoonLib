function tycoonLib.TouchBuy(objInstance,objName,callbackFun,StationNumber)
	warn(objInstance.Name)
	local Location = objInstance.Location
	local player = objInstance.Player
	local tycoonData = objInstance.TycoonData
	
	local index = tycoonLib.GetValue(tycoonData,StationNumber,objName) + 1
	local buyPartForObj = Location["BuyParts"][objName]:FindFirstChild(objName..tostring(index))
	
	
	if not buyPartForObj then
		warn("No more "..objName.." parts to buy")
		return 
	end
	
	buyPartForObj.CanTouch = true
	buyPartForObj.Transparency = 0
	
	local connection
	
	local price = tycoonLib.PriceCalu(objName,index)
	local priceDisplay = tycoonLib.BillboardDisplay("Price")
	priceDisplay.TextLabel.Text = tostring(price.." $")
	priceDisplay.Parent = buyPartForObj
	TycoonBuy:FireAllClients(player)
	
	connection = buyPartForObj.Touched:Connect(function(hit)	
		if playerLib.CheckforPlayer(hit,player) and tycoonLib.Transaction(player,price) then
			tycoonLib.IncrementData(tycoonData,StationNumber,objName)
			connection:Disconnect()
			buyPartForObj:Destroy()
			callbackFun()
		end
	end)
end

function tycoonLib.Transaction(player,price)
	if player.leaderstats.Money.Value >= price then
		player.leaderstats.Money.Value -= price
		print("Something Bought")
		return true
	else
		print("Not enough moneys")
		return false
	end
end 

