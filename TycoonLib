function tycoonLib.ReachedLimit(TycoonInstance,objName)
	local TycoonData = TycoonInstance.TycoonData
	local currentStationData = TycoonData.StationData[TycoonData.Station][objName]
	-- make dropperlimit more modular when needs be 
	if currentStationData % TycoonInstance.DropperLimit == 0 and currentStationData ~= 0 then
		return true
	end
	return false
end

